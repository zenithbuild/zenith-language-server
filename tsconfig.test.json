{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./.test-dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/contracts.ts",
    "src/project.ts",
    "src/settings.ts",
    "src/diagnostics.ts",
    "src/code-actions.ts",
    "src/imports.ts",
    "src/metadata/**/*.ts",
    "src/**/*.d.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".test-dist"
  ]
}
